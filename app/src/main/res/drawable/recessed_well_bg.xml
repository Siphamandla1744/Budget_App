<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active State: Glow/Highlight -->
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <solid android:color="#2600E5FF" />
                    <stroke
                        android:width="1dp"
                        android:color="#8000E5FF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Normal State: Recessed Well -->
    <item>
        <layer-list>
            <!-- Inner Shadow (Dark top/left) -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#0D000000" />
                </shape>
            </item>
            <!-- Inner Highlight (Light bottom/right) -->
            <item
                android:bottom="1dp"
                android:left="1dp"
                android:right="1dp"
                android:top="1dp">
                <shape android:shape="oval">
                    <stroke
                        android:width="1dp"
                        android:color="#1AFFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>