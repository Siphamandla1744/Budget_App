<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Shadow (Ambient) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <solid android:color="#4D000000" />
        </shape>
    </item>

    <!-- Main Glass Body -->
    <item
        android:bottom="2dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <gradient
                android:angle="270"
                android:centerColor="#26FFFFFF"
                android:endColor="#1AFFFFFF"
                android:startColor="#33FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#4DFFFFFF" />
        </shape>
    </item>

    <!-- Top Bevel Highlight -->
    <item
        android:bottom="30dp"
        android:left="20dp"
        android:right="20dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <solid android:color="#4DFFFFFF" />
        </shape>
    </item>
</layer-list>